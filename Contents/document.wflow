<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>AMApplicationBuild</key>
	<string>533</string>
	<key>AMApplicationVersion</key>
	<string>2.10</string>
	<key>AMDocumentVersion</key>
	<string>2</string>
	<key>actions</key>
	<array>
		<dict>
			<key>action</key>
			<dict>
				<key>AMAccepts</key>
				<dict>
					<key>Container</key>
					<string>List</string>
					<key>Optional</key>
					<true/>
					<key>Types</key>
					<array>
						<string>com.apple.applescript.object</string>
					</array>
				</dict>
				<key>AMActionVersion</key>
				<string>1.0</string>
				<key>AMApplication</key>
				<array>
					<string>Automator</string>
				</array>
				<key>AMParameterProperties</key>
				<dict>
					<key>source</key>
					<dict/>
				</dict>
				<key>AMProvides</key>
				<dict>
					<key>Container</key>
					<string>List</string>
					<key>Types</key>
					<array>
						<string>com.apple.applescript.object</string>
					</array>
				</dict>
				<key>ActionBundlePath</key>
				<string>/System/Library/Automator/Run JavaScript.action</string>
				<key>ActionName</key>
				<string>Exécuter JavaScript</string>
				<key>ActionParameters</key>
				<dict>
					<key>source</key>
					<string>/*
Mail → LLM → Calendar (JXA)

Select an email in Apple Mail, run this.
Provider: "ollama" or "openai"
*/

ObjC.import("stdlib");
ObjC.import("Foundation");

const CONFIG = {
  provider: "mlx", // "mlx", "ollama", or "openai"
  timezone: ObjC.unwrap($.NSTimeZone.systemTimeZone.name) || "Europe/Brussels",
  defaultDurationMinutes: 60,

  // Ollama (native /api/chat format)
  ollamaUrl: "http://localhost:11434/api/chat",
  ollamaModel: "gpt-oss:latest",

  // MLX LM Server (OpenAI-compatible API, e.g. mlx_lm.server --port 11434)
  mlxUrl: "http://localhost:11434/v1/chat/completions",
  mlxModel: "mlx-community/Mistral-7B-Instruct-v0.3-4bit", // ← change to your loaded model name

  // OpenAI
  openaiUrl: "https://api.openai.com/v1/chat/completions",
  openaiModel: "gpt-5-mini",
  openaiApiKey: "", // leave blank to read from Keychain (recommended)
	openaiKeychainService: "openai-API-token",
	openaiKeychainAccount: ObjC.unwrap($.NSProcessInfo.processInfo.environment.objectForKey('USER')) || "default",
};

function run() {
	const app = Application.currentApplication();
	app.includeStandardAdditions = true;

	const logPath = defaultLogPath();
	app.displayNotification("Processing most recent email of the thread…", { withTitle: "Mail to Calendar" });

	let mailText = "";
	let prompt = "";
	let llmJsonText = "";

	try {
		mailText = getSelectedMailText();
		prompt = buildPrompt(mailText);

		let providerUsed = CONFIG.provider; // set via CONFIG.provider: "mlx", "ollama", or "openai"
		let eventsToCreate = [];

		while (true) {
			llmJsonText = (providerUsed === "ollama")
				? callOllama(prompt)
				: (providerUsed === "mlx")
				? callMLX(prompt)
				: callOpenAI(prompt);

			eventsToCreate = parseEventsFromLlm(llmJsonText, app);
			if (eventsToCreate.length === 0) {
				throw new Error("No valid events detected (missing title or start). See log for LLM output.");
			}

			const action = createIcsAndHandle(eventsToCreate, providerUsed === "ollama" || providerUsed === "mlx");
			if (action === "retry-openai") {
				providerUsed = "openai";
				continue;
			}
			if (action === "cancel") {
				return;
			}
			break;
		}

		const summary = (eventsToCreate.length === 1)
			? `Draft prepared: ${eventsToCreate[0].title}`
			: `Draft prepared: ${eventsToCreate.length} events`;
		app.displayNotification(summary, { withTitle: "Mail to Calendar" });
	} catch (e) {
		logToFile(logPath, buildLogPayload({ error: e, mailText, prompt, llmJsonText }));
		app.displayNotification("Failed. See log: " + logPath, { withTitle: "Mail to Calendar" });
		throw e;
	}
}

function getSelectedMailText() {
	const m = getFocusedMessage();
	if (!m) throw new Error("No message selected in Mail.");
  const subject = m.subject() || "";
  const sender = m.sender() || "";
  const received = String(m.dateReceived() || "");
  let body = "";
  try { body = m.content() || ""; } catch (e) { body = ""; }

  return `From: ${sender}\nSubject: ${subject}\nReceived: ${received}\n\n${body}`;
}

function getFocusedMessage() {
	const Mail = Application("Mail");
	let msgs = [];

	try {
		const viewers = Mail.messageViewers();
		if (viewers &amp;&amp; viewers.length > 0) {
			const selected = viewers[0].selectedMessages();
			if (selected &amp;&amp; selected.length > 0) msgs = selected;
		}
	} catch (e) {}

	if (!msgs || msgs.length === 0) {
		try {
			const sel = Mail.selection();
			if (sel &amp;&amp; sel.length > 0) msgs = sel;
		} catch (e) {}
	}

	if (!msgs || msgs.length === 0) return null;

	const sorted = Array.from(msgs).sort((a, b) => {
		const da = new Date(a.dateReceived() || 0).getTime();
		const db = new Date(b.dateReceived() || 0).getTime();
		return db - da;
	});

	return sorted[0] || null;
}

function buildPrompt(mailText) {
  return [
    "Extract a calendar event from the email below.",
    "Return ONLY valid JSON (no markdown) with keys:",
    "title, start, end, timezone, location, notes, attendees, confidence",
    "Rules:",
    `- start/end must be ISO 8601 (e.g. 2026-01-18T14:00:00+01:00)`,
    "- If end is unknown, omit it (I'll default duration).",
    `- If timezone unknown, set timezone="${CONFIG.timezone}" and use it in start/end offsets.`,
    '- If no event can be inferred, set confidence=0 and title="".',
    "- notes should include useful context (speaker, agenda, link, address).",
    "",
    "EMAIL:",
    mailText,
  ].join("\n");
}

function callOllama(promptText) {
  const payload = {
    model: CONFIG.ollamaModel,
    stream: false,
    messages: [
      { role: "system", content: "You extract calendar events from emails and output ONLY JSON." },
      { role: "user", content: promptText },
    ],
  };
  const resp = httpPostJson(CONFIG.ollamaUrl, payload, {});
  // { message: { content: "..." }, ... }
  return (resp &amp;&amp; resp.message &amp;&amp; resp.message.content) ? String(resp.message.content) : "";
}

function callMLX(promptText) {
  // mlx_lm.server exposes an OpenAI-compatible API at /v1/chat/completions.
  // It does NOT accept a leading "system" role — roles must alternate user/assistant.
  // We prepend the system instruction directly into the user message instead.
  const systemInstruction = "You extract calendar events from emails and output ONLY JSON. No markdown, no explanation.";
  const payload = {
    model: CONFIG.mlxModel,
    messages: [
      { role: "user", content: systemInstruction + "\n\n" + promptText },
    ],
    temperature: 0.1,
  };
  const resp = httpPostJson(CONFIG.mlxUrl, payload, {});
  const content = resp &amp;&amp; resp.choices &amp;&amp; resp.choices[0] &amp;&amp; resp.choices[0].message &amp;&amp; resp.choices[0].message.content;
  if (!content) {
    if (resp &amp;&amp; resp.error) throw new Error("MLX API error: " + JSON.stringify(resp.error));
    throw new Error("MLX returned empty content. Full response logged to: " + defaultLogPath());
  }
  return String(content);
}

function callOpenAI(promptText) {
  const apiKey = CONFIG.openaiApiKey || readKeychain(CONFIG.openaiKeychainService, CONFIG.openaiKeychainAccount);
  if (!apiKey) throw new Error("OpenAI API key missing (set CONFIG.openaiApiKey or store in Keychain as openai-API-token).");

  const payload = {
    model: CONFIG.openaiModel,
    messages: [
      { role: "system", content: "You extract calendar events from emails and output ONLY JSON." },
      { role: "user", content: promptText },
    ],
    temperature: 1,
  };

  const resp = httpPostJson(CONFIG.openaiUrl, payload, { Authorization: `Bearer ${apiKey}` });
	const content = resp?.choices?.[0]?.message?.content;
	  if (!content) {
	    if (resp &amp;&amp; resp.error) {
			throw new Error("OpenAI API error: " + JSON.stringify(resp.error));
		}
		throw new Error("OpenAI returned empty content. Response: " + JSON.stringify(resp));
	}
	return String(content);
}

function httpPostJson(url, payloadObj, extraHeaders) {
  const app = Application.currentApplication();
  app.includeStandardAdditions = true;

  const payloadStr = JSON.stringify(payloadObj);

  const headerArgs = Object.entries(extraHeaders || {}).flatMap(([k, v]) =&gt; ["-H", `${k}: ${v}`]);

  const cmd = [
    "/usr/bin/curl", "-s",
    "-H", "Content-Type: application/json",
    ...headerArgs,
    "-d", payloadStr,
    url,
  ];

  const out = app.doShellScript(cmd.map(shellEscape).join(" "));

  // Debug: always log the raw HTTP response so we can inspect what the server returns
  try {
    const _dbgPath = defaultLogPath();
    logToFile(_dbgPath, JSON.stringify({
      debug_url: url,
      debug_status: out.slice(0, 120),
      debug_raw_response: out.slice(0, 8000),
    }, null, 2));
  } catch (_dbgErr) {}

  try { return JSON.parse(out); } catch (e) { throw new Error("Non-JSON HTTP response:\n" + out); }
}

function readKeychain(service, account) {
  const app = Application.currentApplication();
  app.includeStandardAdditions = true;
  try {
    const cmd = `security find-generic-password -s ${shellEscape(service)} -a ${shellEscape(account)} -w`;
    return app.doShellScript(cmd).trim();
  } catch (e) {
    return "";
  }
}

function isoPlusMinutes(isoStr, mins) {
  const d = new Date(isoStr);
  if (isNaN(d.getTime())) throw new Error("Invalid ISO date: " + isoStr);
  return new Date(d.getTime() + mins * 60000).toISOString();
}

function parseEventsFromLlm(llmJsonText, app) {
	if (!llmJsonText || !llmJsonText.trim()) throw new Error("LLM returned empty response.");

	let evt;
	try {
		evt = JSON.parse(llmJsonText);
	} catch (e) {
		throw new Error("LLM did not return valid JSON. Response was:\n" + llmJsonText);
	}

	const events = Array.isArray(evt) ? evt : [evt];
	const eventsToCreate = [];

	for (const item of events) {
		const title = (item?.title || "").trim();
		const start = (item?.start || "").trim();
		let end = (item?.end || "").trim();
		const location = (item?.location || "").trim();
		const notes = (item?.notes || "").trim();
		const confidence = (typeof item?.confidence === "number") ? item.confidence : null;

		if (!title || !start) continue;

		if (!end) end = isoPlusMinutes(start, CONFIG.defaultDurationMinutes);

		if (confidence !== null &amp;&amp; confidence &lt; 0.5) {
			const r = app.displayDialog(`Low confidence (${confidence}). Create event anyway?`, {
				buttons: ["Cancel", "Create"],
				defaultButton: "Cancel",
			});
			if (r.buttonReturned === "Cancel") continue;
		}

		eventsToCreate.push({
			title,
			startISO: start,
			endISO: end,
			location,
			notes,
		});
	}

	return eventsToCreate;
}

function createIcsAndHandle(events, allowRetry) {
	const app = Application.currentApplication();
	app.includeStandardAdditions = true;

	const icsContent = buildIcs(events);
	const path = tempIcsPath();

	app.doShellScript(`printf %s ${shellEscape(icsContent)} > ${shellEscape(path)}`);

	const preview = buildHumanPreview(events);
	const choice = safeDisplayDialog(preview, {
		withTitle: "Mail to Calendar",
		buttons: ["Cancel", "Edit", "OK"],
		defaultButton: "OK",
		cancelButton: "Cancel",
	});
	if (!choice) {
		if (allowRetry) {
			const retryChoice = safeDisplayDialog("Retry analysis with ChatGPT?", {
				withTitle: "Mail to Calendar",
				buttons: ["Cancel", "Retry with ChatGPT"],
				defaultButton: "Retry with ChatGPT",
				cancelButton: "Cancel",
			});
			if (retryChoice &amp;&amp; retryChoice.buttonReturned === "Retry with ChatGPT") {
				app.doShellScript(`/bin/rm -f ${shellEscape(path)}`);
				return "retry-openai";
			}
		}
		return "cancel";
	}

	if (choice.buttonReturned === "Edit") {
		const before = getFileMtime(path);
		app.doShellScript(`/usr/bin/open -t ${shellEscape(path)}`);
		const changed = waitForFileChange(path, before, 600);
		if (changed) app.doShellScript(`/usr/bin/open -a Calendar ${shellEscape(path)}`);
	} else if (choice.buttonReturned === "OK") {
		app.doShellScript(`/usr/bin/open -a Calendar ${shellEscape(path)}`);
	}

	return path;
}

function safeDisplayDialog(text, options) {
	const app = Application.currentApplication();
	app.includeStandardAdditions = true;
	try {
		return app.displayDialog(text, options);
	} catch (e) {
		return null;
	}
}

function buildHumanPreview(events) {
	const parts = ["Draft calendar event(s):", ""];
	for (const ev of events) {
		const start = new Date(ev.startISO);
		const end = new Date(ev.endISO);
		const startStr = isNaN(start.getTime()) ? ev.startISO : start.toLocaleString();
		const endStr = isNaN(end.getTime()) ? ev.endISO : end.toLocaleString();
		parts.push(`• ${ev.title}`);
		parts.push(`  When: ${startStr} → ${endStr}`);
		if (ev.location) parts.push(`  Where: ${ev.location}`);
		if (ev.notes) parts.push(`  Notes: ${truncatePreview(ev.notes)}`);
		parts.push("");
	}
	parts.push("Choose OK to open in Calendar, Edit to open the .ics file, or Cancel.");
	return parts.join("\n");
}

function truncatePreview(text) {
	const s = String(text).replace(/\s+/g, " ").trim();
	return s.length > 200 ? s.slice(0, 200) + "…" : s;
}

function getFileMtime(path) {
	const app = Application.currentApplication();
	app.includeStandardAdditions = true;
	try {
		const out = app.doShellScript(`/usr/bin/stat -f %m ${shellEscape(path)}`);
		return parseInt(out, 10) || 0;
	} catch (e) {
		return 0;
	}
}

function waitForFileChange(path, previousMtime, timeoutSeconds) {
	const app = Application.currentApplication();
	app.includeStandardAdditions = true;
	const start = Date.now();
	while ((Date.now() - start) / 1000 &lt; timeoutSeconds) {
		app.doShellScript("/bin/sleep 1");
		const mtime = getFileMtime(path);
		if (mtime > previousMtime) return true;
	}
	return false;
}

function buildIcs(events) {
	const lines = [
		"BEGIN:VCALENDAR",
		"VERSION:2.0",
		"PRODID:-//MailToCalendar//EN",
		"CALSCALE:GREGORIAN",
	];

	const dtstamp = formatIcsDate(new Date());

	for (const ev of events) {
		const start = new Date(ev.startISO);
		const end = new Date(ev.endISO);
		if (isNaN(start.getTime())) throw new Error("Invalid start date: " + ev.startISO);
		if (isNaN(end.getTime())) throw new Error("Invalid end date: " + ev.endISO);

		lines.push("BEGIN:VEVENT");
		lines.push("UID:" + generateUid());
		lines.push("DTSTAMP:" + dtstamp);
		lines.push("DTSTART:" + formatIcsDate(start));
		lines.push("DTEND:" + formatIcsDate(end));
		lines.push("SUMMARY:" + escapeIcsText(ev.title));
		if (ev.location) lines.push("LOCATION:" + escapeIcsText(ev.location));
		if (ev.notes) lines.push("DESCRIPTION:" + escapeIcsText(ev.notes));
		lines.push("END:VEVENT");
	}

	lines.push("END:VCALENDAR");
	return lines.join("\r\n") + "\r\n";
}

function formatIcsDate(date) {
	const y = date.getUTCFullYear();
	const m = String(date.getUTCMonth() + 1).padStart(2, "0");
	const d = String(date.getUTCDate()).padStart(2, "0");
	const hh = String(date.getUTCHours()).padStart(2, "0");
	const mm = String(date.getUTCMinutes()).padStart(2, "0");
	const ss = String(date.getUTCSeconds()).padStart(2, "0");
	return `${y}${m}${d}T${hh}${mm}${ss}Z`;
}

function escapeIcsText(text) {
	return String(text)
		.replace(/\\/g, "\\\\")
		.replace(/\n/g, "\\n")
		.replace(/\r/g, "")
		.replace(/;/g, "\\;")
		.replace(/,/g, "\\,");
}

function generateUid() {
	const rand = Math.random().toString(36).slice(2, 10);
	return `${Date.now()}-${rand}@mail-to-calendar`;
}

function tempIcsPath() {
	const tmp = ObjC.unwrap($.NSTemporaryDirectory());
	return tmp.replace(/\/$/, "") + `/MailToCalendar-${Date.now()}.ics`;
}

function shellEscape(s) {
  // minimal safe single-quote escape for shell
  const str = String(s);
  return "'" + str.replace(/'/g, "'\\''") + "'";
}

function defaultLogPath() {
	const home = ObjC.unwrap($.NSHomeDirectory());
	return home + "/Library/Logs/MailToCalendar.log";
}

function buildLogPayload({ error, mailText, prompt, llmJsonText }) {
	const errText = (error &amp;&amp; error.stack) ? String(error.stack) : String(error);
	return JSON.stringify({
		error: errText,
		mailText: mailText || "",
		prompt: prompt || "",
		llmJsonText: llmJsonText || "",
	}, null, 2);
}

function logToFile(path, text) {
	const app = Application.currentApplication();
	app.includeStandardAdditions = true;

	const dir = path.replace(/\/[^\/]+$/, "");
	app.doShellScript(`/bin/mkdir -p ${shellEscape(dir)}`);

	const payload = `\n[${new Date().toISOString()}]\n${text}\n`;
	app.doShellScript(`printf %s ${shellEscape(payload)} &gt;&gt; ${shellEscape(path)}`);
}
</string>
